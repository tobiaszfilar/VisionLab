<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VisionLab.UI.ViewModels"
        xmlns:images="using:VisionLab.Shared.Images"
        x:Class="VisionLab.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="VisionLAB"
        Width="1200"
        Height="800">

    <Grid RowDefinitions="Auto,*,Auto"
          Margin="16"
          RowSpacing="12">

        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    Spacing="8">

            <Button Content="Refresh"
                    Command="{Binding RefreshCommand}" />

            <Button Content="Upload"
                    Command="{Binding UploadCommand}" />

            <TextBlock Text="{Binding StatusMessage}"
                       VerticalAlignment="Center"
                       Margin="12,0,0,0" />

        </StackPanel>

        <Grid Grid.Row="1"
              ColumnDefinitions="2*,3*"
              ColumnSpacing="12">

            <Border Grid.Column="0"
                    BorderThickness="1"
                    Padding="8">

                <ListBox ItemsSource="{Binding Images}"
                         SelectedItem="{Binding SelectedImage, Mode=TwoWay}">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="images:ImageAssetDto">
                            <Border Padding="8">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Binding OriginalFileName}"
                                               FontWeight="Bold" />

                                    <TextBlock Text="{Binding ContentType}" />

                                    <TextBlock Text="{Binding SizeInBytes}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

            </Border>

            <Border Grid.Column="1"
                    BorderThickness="1"
                    Padding="8">

                <Image Source="{Binding PreviewImage}"
                       Stretch="Uniform" />

            </Border>

        </Grid>

        <TextBlock Grid.Row="2"
                   Text="VisionLAB - Sprint 1"
                   Opacity="0.6" />

    </Grid>
</Window>